<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProjetoLoja</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    @* IMPORTANTE: Link para os ícones do Bootstrap *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjetoLoja.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shop me-1"></i> ProjetoLoja
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    @* LADO ESQUERDO DO MENU *@
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door"></i> Home
                            </a>
                        </li>

                        @* Só mostra o menu de Estoque para quem está LOGADO *@
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Produto" asp-action="Index">
                                    <i class="bi bi-box-seam"></i> Gerenciar Estoque
                                </a>
                            </li>
                        }
                    </ul>

                    @* LADO DIREITO DO MENU (Autenticação) *@
                    <ul class="navbar-nav">
                        @if (User.Identity.IsAuthenticated)
                        {
                            @* Mostra o nome do usuário estilizado e o botão Sair *@
                            <li class="nav-item d-flex align-items-center me-3">
                                <span class="badge rounded-pill bg-light text-primary border p-2">
                                    <i class="bi bi-person-circle me-1"></i> Olá, @User.Identity.Name!
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm mt-1 shadow-sm" asp-controller="Usuario" asp-action="Sair">
                                    <i class="bi bi-box-arrow-right"></i> Sair
                                </a>
                            </li>
                        }
                        else
                        {
                            @* Se NÃO estiver logado, mostra o botão para Entrar *@
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm px-4 fw-bold shadow-sm" asp-controller="Usuario" asp-action="Login">
                                    <i class="bi bi-person-lock me-1"></i> Entrar
                                </a>

                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>